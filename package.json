  "author": "Zmole Cristian",
  "license": "0BSD",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "node discipline/scanner.js",
    "build": "tsc",
    "check": "node discipline/scanner.js",
