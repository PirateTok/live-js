  },
  "keywords": [
    "tiktok",
    "tiktok-live",
    "live",
    "stream",
    "chat",
    "gifts",
    "websocket",
    "protobuf",
    "realtime",
    "piratetok",
    "events"
  ],
  "dependencies": {
    "protobufjs": "^7.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
